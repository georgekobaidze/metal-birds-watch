# Server
PORT=3000
NODE_ENV=development

# OpenSky API
OPENSKY_BASE_URL=url-to-opensky-api-here
OPENSKY_AUTH_URL=url-to-opensky-auth-here
OPENSKY_CLIENT_ID=your_client_id_here
OPENSKY_CLIENT_SECRET=your_client_secret_here

# CORS (comma-separated origins)
# Replace https://example.com with your production domain (e.g., https://yourdomain.com)
CORS_ORIGINS=http://localhost:3000,https://example.com

# Admin API
ADMIN_API_KEY=your_secure_random_key_here